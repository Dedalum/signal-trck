# LLM provider selection (used in Phase A.3 — not yet active)
# Pick one provider; only that provider's API key needs to be set.
LLM_PROVIDER=anthropic
LLM_MODEL=

# Provider API keys — set the one matching LLM_PROVIDER
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=

# Optional: CoinGecko Demo key (used in Phase D for altcoin fallback)
COINGECKO_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
