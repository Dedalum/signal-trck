                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pairs/{pair_id}/indicators/{name}": {
      "get": {
        "summary": "Get Indicator",
        "description": "Return a (potentially multi-output) indicator series.\n\nPer Decision 20: the ``name`` path param dispatches to a per-indicator\nparams shape. SMA/EMA/RSI take ``period``; MACD takes ``fast``/``slow``/\n``signal``; BB takes ``period``/``stddev``. Unknown ``name`` \u2192 422.",
        "operationId": "get_indicator_pairs__pair_id__indicators__name__get",
        "parameters": [
          {
            "name": "pair_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Pair Id"
            }
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "1h",
                "1d",
                "1w"
              ],
              "type": "string",
              "default": "1d",
              "title": "Interval"
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 500,
                  "minimum": 2
                },
                {
                  "type": "null"
                }
              ],
              "title": "Period"
            }
          },
          {
            "name": "fast",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 200,
                  "minimum": 2
                },
                {
                  "type": "null"
                }
              ],
              "title": "Fast"
            }
          },
          {
            "name": "slow",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 500,
                  "minimum": 3
                },
                {
                  "type": "null"
                }
              ],
              "title": "Slow"
            }
          },
          {
            "name": "signal",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 200,
                  "minimum": 2
                },
                {
                  "type": "null"
                }
              ],
              "title": "Signal"
            }
          },
          {
            "name": "stddev",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 10,
                  "exclusiveMinimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "title": "Stddev"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndicatorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
