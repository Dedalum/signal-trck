    "/charts/import": {
      "post": {
        "summary": "Import Chart",
        "description": "Multipart upload of a ``chart.json`` file.\n\nGoes through ``chart_io.parse_chart_json`` so a ``schemaVersion``\nmismatch surfaces as ``SchemaVersionError`` (\u2192 422 SCHEMA_MISMATCH),\nnot a generic ``ValidationError``.",
        "operationId": "import_chart_charts_import_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_import_chart_charts_import_post"
              }
            }
          },
          "required": true
        },
        "responses": {
