  "components": {
    "schemas": {
      "AIRun": {
        "properties": {
          "model": {
            "type": "string",
            "title": "Model"
          },
          "prompt_template_version": {
            "type": "string",
            "title": "Prompt Template Version"
          },
          "context_file_sha256": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context File Sha256"
          },
          "context_preview": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Preview"
          },
          "sr_candidates_presented": {
            "items": {
              "$ref": "#/components/schemas/SRCandidate"
            },
            "type": "array",
            "title": "Sr Candidates Presented"
          },
          "sr_candidates_selected": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sr Candidates Selected"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "model",
          "prompt_template_version",
          "sr_candidates_presented",
          "sr_candidates_selected"
        ],
        "title": "AIRun",
        "description": "Audit record for an AI-produced chart. Populated only on AI charts."
      },
      "AIRunResponse": {
        "properties": {
          "run_id": {
            "type": "integer",
            "title": "Run Id"
          },
          "pair_id": {
            "type": "string",
            "title": "Pair Id"
          },
          "chart_slug": {
            "type": "string",
            "title": "Chart Slug"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "prompt_template_version": {
            "type": "string",
            "title": "Prompt Template Version"
          },
          "context_file_sha256": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context File Sha256"
          },
          "context_preview": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context Preview"
          },
          "sr_candidates_selected": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sr Candidates Selected"
          },
          "ran_at": {
            "type": "integer",
            "title": "Ran At"
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "pair_id",
          "chart_slug",
          "model",
          "provider",
          "prompt_template_version",
          "sr_candidates_selected",
          "ran_at"
        ],
        "title": "AIRunResponse"
      },
      "Anchor": {
        "properties": {
          "ts_utc": {
            "type": "integer",
            "title": "Ts Utc"
          },
          "price": {
            "type": "number",
            "title": "Price"
          },
          "candidate_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Candidate Id"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "ts_utc",
          "price"
        ],
        "title": "Anchor",
        "description": "A single anchor on a drawing.\n\n``candidate_id`` is set on AI-created drawings to record which S/R\ncandidate the model picked (the price is then resolved server-side).\nOn user drawings ``candidate_id`` is ``None`` and ``price`` is whatever\nthe user dragged the line to."
      },
      "Body_import_chart_charts_import_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_import_chart_charts_import_post"
      },
      "CandleResponse": {
        "properties": {
          "ts_utc": {
            "type": "integer",
            "title": "Ts Utc"
          },
          "open": {
            "type": "number",
            "title": "Open"
          },
          "high": {
            "type": "number",
            "title": "High"
          },
          "low": {
            "type": "number",
            "title": "Low"
          },
          "close": {
            "type": "number",
            "title": "Close"
          },
          "volume": {
            "type": "number",
            "title": "Volume"
          }
        },
        "type": "object",
        "required": [
          "ts_utc",
          "open",
          "high",
          "low",
          "close",
          "volume"
        ],
        "title": "CandleResponse"
      },
      "Chart": {
        "properties": {
          "schemaVersion": {
            "type": "integer",
            "title": "Schemaversion",
            "default": 1
          },
          "slug": {
            "type": "string",
            "title": "Slug"
          },
