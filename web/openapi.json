    "/pairs/{pair_id}/candles": {
      "get": {
        "summary": "Get Candles",
        "operationId": "get_candles_pairs__pair_id__candles_get",
        "parameters": [
          {
            "name": "pair_id",
            "in": "path",
            "required": true,
