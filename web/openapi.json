              "type": "string",
              "title": "Pair Id"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "1h",
                "1d",
                "1w"
              ],
              "type": "string",
              "default": "1d",
              "title": "Interval"
            }
          },
          {
            "name": "window_days",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 3650,
              "minimum": 1,
              "default": 90,
              "title": "Window Days"
